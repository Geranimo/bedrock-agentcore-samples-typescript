{
  "name": "amazon-bedrock-agentcore-samples-typescript",
  "version": "0.1.0",
  "description": "Examples and tutorials for AWS Bedrock AgentCore TypeScript SDK",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yaml,yml}\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run type-check"
  },
  "keywords": [
    "aws",
    "bedrock",
    "agentcore",
    "agents",
    "ai",
    "typescript",
    "samples",
    "examples"
  ],
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.0-beta.67",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ai": "^6.0.0-beta.114",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "bedrock-agentcore": "^0.1.1",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/awslabs/amazon-bedrock-agentcore-samples-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/awslabs/amazon-bedrock-agentcore-samples-typescript/issues"
  },
  "homepage": "https://github.com/awslabs/amazon-bedrock-agentcore-samples-typescript#readme"
}
