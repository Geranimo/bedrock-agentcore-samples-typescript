{
  "name": "agentcore-browser-liveview-agent-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Watch an AI agent browse the web in real time — Bedrock AgentCore Browser + Live View + Vercel AI SDK",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@babel/runtime": "^7.0.0",
    "@cloudscape-design/components": "^3.0.0",
    "@cloudscape-design/design-tokens": "^3.0.0",
    "@cloudscape-design/global-styles": "^1.0.0",
    "bedrock-agentcore": "^0.2.2",
    "fastify": "^5.7.0",
    "playwright": "^1.56.0",
    "prop-types": "^15.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^3.0.2"
  }
}
