{
  "name": "customer-support-agent",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "docker-compose up --build",
    "start": "tsx watch src/index.ts",
    "build": "./node_modules/typescript/bin/tsc",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "bootstrap": "cdk bootstrap"
  },
  "dependencies": {
    "@strands-agents/sdk": "^0.1.4",
    "bedrock-agentcore": "^0.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-agentcore": "^3.1041.0",
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.170.0",
    "aws-cdk-lib": "^2.240.0",
    "constructs": "^10.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
