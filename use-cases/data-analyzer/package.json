{
  "name": "data-analyzer",
  "version": "1.0.0",
  "description": "Data analysis agent using AgentCore Code Interpreter with CDK deployment",
  "type": "module",
  "scripts": {
    "dev": "docker-compose up --build",
    "start": "tsx watch src/index.ts",
    "build": "./node_modules/typescript/bin/tsc",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "bootstrap": "cdk bootstrap"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@strands-agents/sdk": "^0.1.0",
    "bedrock-agentcore": "^0.2.0",
    "dotenv": "^16.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.170.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
